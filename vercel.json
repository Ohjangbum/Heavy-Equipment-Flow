{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "functions": {
    "server/index.ts": {
      "runtime": "@vercel/node"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "server/index.ts"
    },
    {
      "source": "/objects/(.*)",
      "destination": "server/index.ts"
    },
    {
      "source": "/((?!api|objects|.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}
